{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functionsDirectory": ".next",
  "routes": [
    {
      "src": "/apresentacao",
      "dest": "/"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/apresentacao/$1"
    }
  ]
}
